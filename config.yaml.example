# ==============================================================================
# SWINGBOT CONFIGURATION EXAMPLE
# Copy this to config.yaml and fill in your values
# ==============================================================================

# -- Exchange Architecture -----------------------------------------------------
# trading_exchange   : where orders are placed (your account)
# market_data_exchange: where we READ market data (public API, no auth needed)
# Strategy: MEXC for trading, Bybit for high-quality market data + funding rates
trading_exchange: mexc               # 'mexc' (recommended) | 'bybit' | 'binance'
market_data_exchange: bybit          # 'bybit' (recommended) | 'binance' — public API only
bybit_account_type: spot             # 'spot' or 'linear' (futures) — only if using bybit trading
trading_mode: paper                  # 'paper' or 'live'

# -- Scan Speed ----------------------------------------------------------------
scan_interval_minutes: 10

# -- Strategy & Scanning -------------------------------------------------------
timeframe: "1h"
lookback: 100
scan_top_n: 20
scanner:
  enabled: true
  breakout_lookback: 20
  btc_correlation_factor: 0.7

# -- Multi-Timeframe Confluence (MTF) -----------------------------------------
# Research: Adding 4H EMA200 filter raises Profit Factor from ~1.4 to ~2.0+
# Only take 1H longs when 4H trend is up; 1H shorts when 4H trend is down
mtf_filter_enabled: true
htf_timeframe: "4h"
htf_ema_period: 200

# -- Funding Rate Filter -------------------------------------------------------
# Bybit public API — no auth needed. Only applies to perpetual symbols (:USDT)
# Positive funding = longs overcrowded → expect squeeze DOWN → avoid longs
# Negative funding = shorts overcrowded → expect squeeze UP → avoid shorts
funding_rate_filter: true
funding_long_block: 0.0008    # Block new longs if funding > 0.08%/8h
funding_short_block: -0.0005  # Block new shorts if funding < -0.05%/8h

# -- Signal Quality Gates ------------------------------------------------------
allow_short: true
min_score: 55                  # Scanner minimum (0-100)
min_rr_ratio: 2.5              # Research minimum for breakout profitability

# -- Risk Management -----------------------------------------------------------
risk_per_trade_percent: 1.0
max_open_positions: 3
max_portfolio_risk_percent: 5.0
max_single_position_percent: 30.0
daily_loss_limit_percent: 2.0
consecutive_loss_limit: 3
api_failure_limit: 3

# -- Compounding Plan ($100 -> $1000) ------------------------------------------
base_balance: 100.0
peak_balance_tracking: true
drawdown_reset_threshold: 0.20

# -- Breakout Detection --------------------------------------------------------
breakout_lookback: 20
breakout_volume_mult: 2.0
breakout_compression_atr: 2.0

# -- Database ------------------------------------------------------------------
db_path: "swingbot.db"

# -- Paper Trading -------------------------------------------------------------
paper_start_balance_usdt: 1000.0

# -- Sentiment Gate ------------------------------------------------------------
sentiment_threshold: 20

# -- Volume Filter -------------------------------------------------------------
min_volume_usdt: 10000000

# -- Polymarket (Macro Filter) -------------------------------------------------
polymarket:
  enabled: false
  update_hours: 6
  markets: []
  default_risk_scale_on_failure: 1.0

# -- Multi-Armed Bandit --------------------------------------------------------
bandit:
  exploration_prob: 0.2

# -- Trading Hours (UTC) -------------------------------------------------------
trading_hours:
  enabled: false               # Set true to restrict entries to certain hours
  avoid_hours_utc: [0, 1, 2, 3, 4]

# -- Account Info --------------------------------------------------------------
account_name: "Swingbot"
live: false
show_balances_on_startup: true

# -- Localization --------------------------------------------------------------
lang: "en"

# -- Dashboard -----------------------------------------------------------------
dashboard:
  enabled: true
  port: 8080
  host: '0.0.0.0'
