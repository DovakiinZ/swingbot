# ── MEXC ──────────────────────────────────────────────────────────
MEXC_API_KEY=
MEXC_API_SECRET=

# ── Bybit (Primary -- Gulf region supported) ─────────────────────
BYBIT_API_KEY=
BYBIT_API_SECRET=

# ── Binance (Optional secondary) ─────────────────────────────────
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# ── Mode ─────────────────────────────────────────────────────────
TRADING_MODE=paper

# ── Dashboard ────────────────────────────────────────────────────
DASHBOARD_PASSWORD=changeme123
FLASK_SECRET_KEY=replace-with-long-random-string

# ── Discord (optional — added from dashboard) ────────────────────
DISCORD_WEBHOOK_GENERAL=
DISCORD_WEBHOOK_TRADES=
DISCORD_WEBHOOK_CLOSED=
DISCORD_WEBHOOK_REPORTS=
DISCORD_WEBHOOK_WARNINGS=

# ── Telegram (optional) ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Custom Webhook (optional) ────────────────────────────────────
CUSTOM_WEBHOOK_URL=
CUSTOM_WEBHOOK_FORMAT=discord

# ── Logging ──────────────────────────────────────────────────────
LOG_LEVEL_CONSOLE=WARNING
LOG_LEVEL_FILE=DEBUG
