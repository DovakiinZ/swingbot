# ── MEXC (Primary trading account) ───────────────────────────────
# mexc.com -> API Management -> Create API Key
# Permissions: Read + Trade ONLY. NEVER enable Withdrawal.
MEXC_API_KEY=
MEXC_API_SECRET=

# ── Bybit (Market data only — public API, no auth needed for data)
# Only fill if you want Bybit as trading account instead of MEXC
BYBIT_API_KEY=
BYBIT_API_SECRET=

# ── Binance (Market data only — public API, no auth needed for data)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ── Mode ─────────────────────────────────────────────────────────
TRADING_MODE=paper

# ── Dashboard ────────────────────────────────────────────────────
DASHBOARD_PASSWORD=changeme123
FLASK_SECRET_KEY=replace-with-long-random-string

# ── Discord (optional — added from dashboard) ────────────────────
DISCORD_WEBHOOK_GENERAL=
DISCORD_WEBHOOK_TRADES=
DISCORD_WEBHOOK_CLOSED=
DISCORD_WEBHOOK_REPORTS=
DISCORD_WEBHOOK_WARNINGS=

# ── Telegram (optional) ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Custom Webhook (optional) ────────────────────────────────────
CUSTOM_WEBHOOK_URL=
CUSTOM_WEBHOOK_FORMAT=discord

# ── AI Chatbot ────────────────────────────────────────────────────
# Get your key from console.anthropic.com
ANTHROPIC_API_KEY=

# ── Logging ──────────────────────────────────────────────────────
LOG_LEVEL_CONSOLE=WARNING
LOG_LEVEL_FILE=DEBUG
